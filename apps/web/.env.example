# URL publica do backend (obrigatoria em qualquer ambiente)
VITE_API_URL=https://api.seudominio.com

# Valor comum para dev local (deixe comentado para nao acoplar producao ao localhost)
# VITE_API_URL=http://localhost:8000

VITE_API_TIMEOUT_MS=20000
VITE_API_RETRY_ATTEMPTS=2
VITE_API_RETRY_DELAY_MS=700
VITE_APP_NAME=SentimentoIA
VITE_DEFAULT_LOCALE=pt-BR
VITE_ENABLE_CHAT=true
VITE_ENABLE_DARK_MODE=true
