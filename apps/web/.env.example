# Endpoint publico do backend (sem barra no final)
VITE_API_URL=https://seu-backend-publico.exemplo.com

# Endpoint canonico de ingestao JSON (caminho relativo ao backend)
VITE_API_INGEST_PATH=api/ingestion/comments

# Timeout e retentativa das chamadas HTTP
VITE_API_TIMEOUT_MS=90000
VITE_API_RETRY_ATTEMPTS=2
VITE_API_RETRY_DELAY_MS=1000

# Features opcionais
VITE_ENABLE_CHAT=true
VITE_ENABLE_NPS=true
VITE_ENABLE_PWA=false

# Idioma inicial da aplicacao (pt-BR ou en-US)
VITE_DEFAULT_LOCALE=pt-BR

# Google Maps (deixe vazio para fallback sem mapa)
VITE_GOOGLE_MAPS_API_KEY=
