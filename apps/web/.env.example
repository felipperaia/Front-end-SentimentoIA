# URL do backend no hostingguru (sem barra final)
VITE_API_URL=https://backend-sentimentoia-python-3872.apps.hostingguru.io

# Timeouts (milissegundos)
VITE_API_TIMEOUT_MS=90000
VITE_API_RETRY_ATTEMPTS=2
VITE_API_RETRY_DELAY_MS=1000

# Google Maps (vazio = mapa desativado com fallback visual)
VITE_GOOGLE_MAPS_API_KEY=

# Locale padrao
VITE_DEFAULT_LOCALE=pt-BR

# PWA
VITE_ENABLE_PWA=false
